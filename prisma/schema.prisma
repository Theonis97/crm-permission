// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ItemType {
  PRODUCT
  SERVICE
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
}

enum OpportunityStatus {
  NEW
  IN_PROGRESS
  WON
  LOST
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ContactType {
  PERSONNE
  ENTREPRISE
}

enum ContactStatus {
  PROSPECT
  CLIENT
  LEAD
  ARCHIVE
}

model Contact {
  id          String   @id @default(cuid())
  firstName   String?  @map("first_name")
  lastName    String?  @map("last_name")
  email       String?
  phone       String?
  photo       String?
  job         String?
  description String?
  tags        String[]

  assignedUserId String        @map("assigned_user_id")
  assignedUser   User          @relation(fields: [assignedUserId], references: [id])
  // tableau de tags
  type           ContactType   @default(PERSONNE)
  status         ContactStatus @default(PROSPECT)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  quotes        Quote[]
  invoices      Invoice[]
  opportunities Opportunity[]
  storeContacts StoreContact[]
  storeOrders   StoreOrder[]

  @@map("contacts")
}

model Store {
  id         String   @id @default(cuid())
  name       String
  logo       String?
  coverImage String?  @map("cover_image")
  address    String?
  phone      String?
  email      String?
  whatsapp   String?
  isActive   Boolean  @default(true) @map("is_active")
  managerId  String?  @map("manager_id") // Manager de la boutique (optionnel)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  manager         User?            @relation("StoreManager", fields: [managerId], references: [id], onDelete: SetNull)
  products        StoreProduct[]
  storeOrders     StoreOrder[]
  orders          Order[] // Commandes d'approvisionnement
  deliveryPersons DeliveryPerson[]
  deliveryZones   DeliveryZone[]
  storeContacts   StoreContact[]
  transfersFrom   Transfer[] @relation("fromStore")
  transfersTo     Transfer[] @relation("toStore")

  @@map("stores")
}

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  logo        String?
  website     String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("brands")
}

model ProductCategory {
  id          String  @id @default(cuid())
  name        String
  description String?

  parentId      String?           @map("parent_id")
  parent        ProductCategory?  @relation("Subcategories", fields: [parentId], references: [id])
  subcategories ProductCategory[] @relation("Subcategories")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_categories")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String?  @unique // Code produit
  description String?
  photos      String[] // tableau d'URLs
  prixVente   Float    @map("prix_vente")
  prixAchat   Float    @map("prix_achat")
  tva         Float    @default(0)
  stock       Int      @default(0)
  minStock    Int      @default(0) @map("min_stock") // Seuil d'alerte stock
  maxStock    Int?     @map("max_stock") // Stock maximum

  // Relations obligatoires et optionnelles
  categoryId String          @map("category_id") // Obligatoire
  category   ProductCategory @relation(fields: [categoryId], references: [id])

  brandId String? @map("brand_id") // Optionnel
  brand   Brand?  @relation(fields: [brandId], references: [id])

  quoteItems              QuoteItem[]
  invoiceItems            InvoiceItem[]
  stockMovements          StockMovement[]
  storeProducts           StoreProduct[]
  warehouseStocks         WarehouseStock[]
  lots                    Lot[]
  transferItems           TransferItem[]
  variants                ProductVariant[]
  storeOrderItems         StoreOrderItem[] // Items des commandes clients
  orderItems              OrderItem[] // Items des commandes d'approvisionnement
  deliveryPersonStocks    DeliveryPersonStock[] // Stock des livreurs
  deliveryStockMovements  DeliveryStockMovement[] // Mouvements de stock des livreurs

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("products")
}

// Variantes de produits (ex: iPhone 14 Pro - 128GB - Noir)
model ProductVariant {
  id        String  @id @default(cuid())
  productId String  @map("product_id")
  sku       String  @unique // SKU spécifique à la variante
  name      String? // Nom de la variante (ex: "iPhone 14 Pro 128GB Noir")

  // Prix spécifiques à la variante (peut différer du produit parent)
  prixVente Float? @map("prix_vente")
  prixAchat Float? @map("prix_achat")

  // Stock spécifique à la variante
  stock    Int @default(0)
  minStock Int @default(0) @map("min_stock")

  // Attributs de la variante (ex: {color: "Noir", size: "128GB"})
  attributes Json // {attributeName: attributeValue}

  // Images spécifiques à la variante
  images String[] @default([])

  // Poids et dimensions (optionnel)
  weight Float? // en kg
  length Float? // en cm
  width  Float? // en cm
  height Float? // en cm

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product                Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeOrderItems        StoreOrderItem[]
  deliveryPersonStocks   DeliveryPersonStock[] // Stock des livreurs pour cette variante
  deliveryStockMovements DeliveryStockMovement[] // Mouvements de stock des livreurs pour cette variante

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model StockMovement {
  id        String    @id @default(cuid())
  productId String    @map("product_id")
  quantity  Int // positif = entrée, négatif = sortie
  type      StockType
  note      String?
  userId    String    @map("user_id")
  lotId     String?   @map("lot_id") // Traçabilité par lot
  createdAt DateTime  @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  lot     Lot?    @relation(fields: [lotId], references: [id])

  @@map("stock_movements")
}

enum StockType {
  ENTRY
  EXIT
  ADJUSTMENT
  SALE
  RETURN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERING
  DELIVERED
  CANCELLED
  REPORTED
}

enum OrderPriority {
  NORMAL
  HIGH
  URGENT
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DeliveryPersonStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum DeliveryStockMovementType {
  SUPPLY       // Approvisionnement depuis le magasin
  SALE         // Vente à un client
  RETURN       // Retour au magasin
  ADJUSTMENT   // Ajustement de stock
}

// Relation produit-magasin (stock par magasin)
model StoreProduct {
  id         String   @id @default(cuid())
  storeId    String   @map("store_id")
  productId  String   @map("product_id")
  stock      Int      @default(0)
  minStock   Int      @default(0) @map("min_stock")
  maxStock   Int?     @map("max_stock") // Seuil max optionnel
  prixVente  Float?   @map("prix_vente") // Prix de vente spécifique au magasin
  prixAchat  Float?   @map("prix_achat") // Prix d'achat spécifique (optionnel)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId])
  @@map("store_products")
}

// Relation contact-magasin (clients du magasin)
model StoreContact {
  id          String    @id @default(cuid())
  storeId     String    @map("store_id")
  contactId   String    @map("contact_id")
  totalOrders Int       @default(0) @map("total_orders")
  totalSpent  Float     @default(0) @map("total_spent")
  lastOrderAt DateTime? @map("last_order_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([storeId, contactId])
  @@map("store_contacts")
}

// Commandes clients du magasin
model StoreOrder {
  id              String  @id @default(cuid())
  number          String  @unique
  storeId         String  @map("store_id")
  contactId       String? @map("contact_id") // Peut être null pour client walk-in
  customerName    String  @map("customer_name")
  customerPhone   String  @map("customer_phone")
  customerEmail   String? @map("customer_email")
  deliveryAddress String? @map("delivery_address")
  deliveryLatitude  Float?  @map("delivery_latitude")
  deliveryLongitude Float?  @map("delivery_longitude")

  status   OrderStatus   @default(PENDING)
  priority OrderPriority @default(NORMAL)

  subtotal      Float @default(0)
  totalDiscount Float @default(0) @map("total_discount")
  totalTax      Float @default(0) @map("total_tax")
  deliveryFee   Float @default(0) @map("delivery_fee")
  total         Float @default(0)

  paymentMethod PaymentMethod @default(CASH) @map("payment_method")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  paidAt        DateTime?     @map("paid_at")
  
  // Nouveaux champs pour la gestion des paiements en espèces
  amountReceived Float? @map("amount_received") // Montant reçu du client
  changeGiven    Float? @map("change_given")    // Monnaie rendue au client

  deliveryPersonId  String?   @map("delivery_person_id")
  deliveryZoneId    String?   @map("delivery_zone_id")
  requestedDeliveryDate DateTime? @map("requested_delivery_date") // Date de livraison souhaitée par le client
  estimatedDelivery DateTime? @map("estimated_delivery")
  deliveredAt       DateTime? @map("delivered_at")

  notes        String?
  cancelReason String? @map("cancel_reason")

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  contact        Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deliveryPerson DeliveryPerson? @relation(fields: [deliveryPersonId], references: [id], onDelete: SetNull)
  deliveryZone   DeliveryZone?   @relation(fields: [deliveryZoneId], references: [id], onDelete: SetNull)
  createdBy      User            @relation(fields: [createdById], references: [id])

  items                  StoreOrderItem[]
  whatsappMessages       WhatsAppMessage[]
  deliveryStockMovements DeliveryStockMovement[] // Mouvements de stock liés à cette commande

  @@map("store_orders")
}

model StoreOrderItem {
  id                String   @id @default(cuid())
  storeOrderId      String   @map("store_order_id")
  productId         String   @map("product_id")
  variantId         String?  @map("variant_id") // Si commande d'une variante spécifique
  name              String // Snapshot du nom au moment de la commande
  sku               String? // Snapshot du SKU
  variantName       String?  @map("variant_name") // Snapshot du nom de la variante
  variantAttributes Json?    @map("variant_attributes") // Snapshot des attributs (couleur, taille, etc.)
  quantity          Int
  unitPrice         Float    @map("unit_price")
  discount          Float    @default(0)
  taxRate           Float    @default(0) @map("tax_rate")
  total             Float
  createdAt         DateTime @default(now()) @map("created_at")

  storeOrder StoreOrder      @relation(fields: [storeOrderId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("store_order_items")
}

// Livreurs
model DeliveryPerson {
  id              String               @id @default(cuid())
  storeId         String               @map("store_id")
  name            String
  phone           String               @unique // Obligatoire et unique
  email           String               @unique // Obligatoire et unique
  password        String // Mot de passe hashé (par défaut "password" sera défini lors de la création)
  avatar          String?
  vehicle         String? // Type de véhicule
  plateNumber     String?              @map("plate_number") // Plaque d'immatriculation
  status          DeliveryPersonStatus @default(AVAILABLE)
  rating          Float? // Note moyenne
  totalDeliveries Int                  @default(0) @map("total_deliveries")
  isActive        Boolean              @default(true) @map("is_active")
  
  // Réinitialisation de mot de passe
  resetPasswordToken       String?              @map("reset_password_token")
  resetPasswordTokenExpiry DateTime?            @map("reset_password_token_expiry")
  resetPasswordCode        String?              @map("reset_password_code") // Code à 6 chiffres
  resetPasswordCodeExpiry  DateTime?            @map("reset_password_code_expiry") // Expiration du code
  
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  store               Store                    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeOrders         StoreOrder[]
  wallet              CourierWallet?
  deliveryZones       DeliveryZone[] // Zones assignées au livreur
  stock               DeliveryPersonStock[] // Stock du livreur
  stockMovements      DeliveryStockMovement[] // Mouvements de stock du livreur
  pushTokens          DeliveryPersonPushToken[] // Tokens de notification push
  dayShifts           DayShift[] // Clôtures de journée

  @@map("delivery_persons")
}

// Zones de livraison
model DeliveryZone {
  id               String   @id @default(cuid())
  storeId          String   @map("store_id")
  name             String
  color            String   @default("#3B82F6") // Couleur pour la carte
  coverage         String? // Description de la couverture
  coordinates      Json // Array de {lat, lng} pour le polygone
  centerLatitude   Float?   @map("center_latitude") // Centre de la zone (calculé)
  centerLongitude  Float?   @map("center_longitude")
  deliveryFee      Float    @default(0) @map("delivery_fee")
  estimatedTime    Int?     @map("estimated_time") // Temps de livraison estimé en minutes
  isActive         Boolean  @default(true) @map("is_active")
  deliveryPersonId String?  @map("delivery_person_id") // Livreur assigné
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deliveryPerson DeliveryPerson? @relation(fields: [deliveryPersonId], references: [id], onDelete: SetNull)
  storeOrders    StoreOrder[]

  @@map("delivery_zones")
}

model Quote {
  id            String      @id @default(cuid())
  number        String      @unique
  contactId     String
  status        QuoteStatus @default(DRAFT)
  title         String
  description   String?
  subtotal      Float       @default(0)
  totalDiscount Float       @default(0)
  totalTax      Float       @default(0)
  total         Float       @default(0)
  validUntil    DateTime
  notes         String?
  terms         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  sentAt        DateTime?
  viewedAt      DateTime?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  userId        String

  contact  Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    QuoteItem[]
  invoices Invoice[]

  @@map("quotes")
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  productId   String?
  name        String
  description String?
  quantity    Int      @default(1)
  unitPrice   Float    @default(0)
  discount    Float    @default(0)
  taxRate     Float    @default(20)
  total       Float    @default(0)
  type        ItemType @default(SERVICE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("quote_items")
}

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  contactId     String
  quoteId       String?
  status        InvoiceStatus @default(DRAFT)
  title         String
  description   String?
  subtotal      Float         @default(0)
  totalDiscount Float         @default(0)
  totalTax      Float         @default(0)
  total         Float         @default(0)
  dueDate       DateTime
  paidAt        DateTime?
  notes         String?
  terms         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sentAt        DateTime?
  userId        String

  contact     Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  quote       Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       InvoiceItem[]
  Opportunity Opportunity[]

  @@map("invoices")
}

model InvoiceItem {
  id        String @id @default(cuid())
  invoiceId String @map("invoice_id")
  productId String @map("product_id")
  quantity  Int
  unitPrice Float  @map("unit_price")

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

model Opportunity {
  id          String            @id @default(cuid())
  title       String
  description String?
  status      OpportunityStatus @default(NEW)
  contactId   String            @map("contact_id")
  ownerId     String            @map("owner_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  contact      Contact                  @relation(fields: [contactId], references: [id])
  owner        User                     @relation(fields: [ownerId], references: [id])
  invoices     Invoice[]
  tasks        Task[]
  documents    OpportunityDocument[]
  participants OpportunityParticipant[]

  @@map("opportunities")
}

model OpportunityDocument {
  id            String   @id @default(cuid())
  opportunityId String   @map("opportunity_id")
  name          String
  url           String
  uploadedAt    DateTime @default(now()) @map("uploaded_at")

  opportunity Opportunity @relation(fields: [opportunityId], references: [id])

  @@map("opportunity_documents")
}

model OpportunityParticipant {
  id            String   @id @default(cuid())
  opportunityId String   @map("opportunity_id")
  userId        String   @map("user_id")
  addedAt       DateTime @default(now()) @map("added_at")

  opportunity Opportunity @relation(fields: [opportunityId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@unique([opportunityId, userId])
  @@map("opportunity_participants")
}

model AuditLog {
  id          String     @id @default(cuid())
  userId      String     @map("user_id")
  action      ActionType
  entity      String // nom du modèle concerné, ex: "Contact"
  entityId    String // ID de l'élément modifié
  description String? // message facultatif
  payload     Json? // snapshot des données modifiées
  createdAt   DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Task {
  id            String     @id @default(cuid())
  title         String
  description   String?
  status        TaskStatus @default(TODO)
  userId        String     @map("user_id")
  opportunityId String?    @map("opportunity_id")
  startDate     DateTime?
  dueDate       DateTime?

  user        User         @relation(fields: [userId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tasks")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  firstName     String?    @map("first_name")
  lastName      String?    @map("last_name")
  password      String? // Ajout du champ mot de passe
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  accounts  Account[]
  sessions  Session[]
  userRoles UserRole[]

  quotes   Quote[]
  invoices Invoice[]

  assignedRoles             UserRole[]               @relation("AssignedBy")
  tasks                     Task[]
  opportunityParticipants   OpportunityParticipant[]
  opportunities             Opportunity[]
  auditLogs         AuditLog[]
  contacts               Contact[]
  stockMovements         StockMovement[]
  storeOrders            StoreOrder[]
  managedStores          Store[]                   @relation("StoreManager")
  managedWarehouses      Warehouse[]
  requestedOrders        Order[]                   @relation("OrderRequester")
  approvedOrders         Order[]                   @relation("OrderApprover")
  deliveryStockMovements DeliveryStockMovement[] // Mouvements de stock des livreurs créés par cet utilisateur

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  module      String
  action      String
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedBy String?  @map("assigned_by")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner User? @relation("AssignedBy", fields: [assignedBy], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================================
// LOGISTIQUE & ENTREPÔTS
// ============================================================================

// Entrepôt central
model Warehouse {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  phone     String?
  managerId String?  @map("manager_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  manager       User?            @relation(fields: [managerId], references: [id])
  stocks        WarehouseStock[]
  transfersFrom Transfer[]       @relation("fromWarehouse")
  transfersTo   Transfer[]       @relation("toWarehouse")

  @@map("warehouses")
}

// Stock par entrepôt
model WarehouseStock {
  id          String   @id @default(cuid())
  warehouseId String   @map("warehouse_id")
  productId   String   @map("product_id")
  quantity    Int      @default(0)
  reserved    Int      @default(0) // Quantité réservée pour commandes en cours
  updatedAt   DateTime @updatedAt @map("updated_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@map("warehouse_stocks")
}

// Statuts des transferts
enum TransferStatus {
  PENDING // En attente
  IN_PROGRESS // En cours
  COMPLETED // Terminé
  CANCELLED // Annulé
}

// Transferts entre entrepôts ou magasins
model Transfer {
  id              String         @id @default(cuid())
  code            String         @unique
  fromWarehouseId String?        @map("from_warehouse_id")
  toWarehouseId   String?        @map("to_warehouse_id")
  fromStoreId     String?        @map("from_store_id")
  toStoreId       String?        @map("to_store_id")
  status          TransferStatus @default(PENDING)
  scheduledAt     DateTime?      @map("scheduled_at")
  completedAt     DateTime?      @map("completed_at")
  notes           String?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  items         TransferItem[]
  fromWarehouse Warehouse?     @relation("fromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse?     @relation("toWarehouse", fields: [toWarehouseId], references: [id])
  fromStore     Store?         @relation("fromStore", fields: [fromStoreId], references: [id])
  toStore       Store?         @relation("toStore", fields: [toStoreId], references: [id])

  @@map("transfers")
}

// Articles dans un transfert
model TransferItem {
  id               String @id @default(cuid())
  transferId       String @map("transfer_id")
  productId        String @map("product_id")
  quantity         Int
  quantityReceived Int?   @map("quantity_received") // Quantité réellement reçue

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("transfer_items")
}

// Lots et dates de péremption
model Lot {
  id            String    @id @default(cuid())
  lotNumber     String    @unique
  productId     String    @map("product_id")
  quantityTotal Int       @map("quantity_total")
  expiryDate    DateTime? @map("expiry_date")
  createdAt     DateTime  @default(now()) @map("created_at")

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@map("lots")
}

// ============================================================================
// GESTION LIVREURS & PORTEFEUILLE
// ============================================================================

// Portefeuille du livreur
model CourierWallet {
  id            String   @id @default(cuid())
  courierId     String   @unique @map("courier_id")
  balance       Float    @default(0)
  currency      String   @default("XAF") // FCFA
  lastUpdatedAt DateTime @updatedAt @map("last_updated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  courier      DeliveryPerson       @relation(fields: [courierId], references: [id], onDelete: Cascade)
  transactions CourierTransaction[]

  @@map("courier_wallets")
}

// Type de transaction livreur
enum TransactionType {
  CREDIT // Crédit (paiement reçu)
  DEBIT // Débit (retrait, commission)
}

// Transactions du portefeuille livreur
model CourierTransaction {
  id          String          @id @default(cuid())
  walletId    String          @map("wallet_id")
  type        TransactionType
  amount      Float
  description String?
  reference   String? // Référence de la commande ou transaction
  createdAt   DateTime        @default(now()) @map("created_at")

  wallet CourierWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("courier_transactions")
}

// ============================================================================
// INTÉGRATION WHATSAPP
// ============================================================================

// Statuts des messages WhatsApp
enum WhatsAppMessageStatus {
  NEW // Nouveau
  PROCESSING // En traitement
  PROCESSED // Traité
  REPLIED // Répondu
  FAILED // Échoué
  IGNORED // Ignoré
}

// Messages WhatsApp reçus/envoyés
model WhatsAppMessage {
  id           String                @id @default(cuid())
  waId         String                @unique @map("wa_id") // WhatsApp message ID
  fromPhone    String                @map("from_phone")
  toPhone      String?               @map("to_phone")
  content      String                @db.Text
  messageType  String                @default("text") @map("message_type") // text, image, audio, etc.
  status       WhatsAppMessageStatus @default(NEW)
  storeOrderId String?               @map("store_order_id")
  processedAt  DateTime?             @map("processed_at")
  errorMessage String?               @map("error_message") @db.Text
  createdAt    DateTime              @default(now()) @map("created_at")

  storeOrder StoreOrder? @relation(fields: [storeOrderId], references: [id])

  @@index([fromPhone])
  @@index([status])
  @@map("whatsapp_messages")
}

// ============================================================================
// COMMANDES D'APPROVISIONNEMENT (RESTOCKING)
// ============================================================================

// Statut de la commande d'approvisionnement
enum RestockingOrderStatus {
  PENDING // En attente de validation
  APPROVED // Approuvée
  PREPARING // En préparation
  SHIPPED // Expédiée
  DELIVERED // Livrée
  CANCELLED // Annulée
  REJECTED // Rejetée
}

// Commandes d'approvisionnement (store vers entrepôt)
model Order {
  id       String                @id @default(cuid())
  number   String                @unique
  storeId  String                @map("store_id")
  status   RestockingOrderStatus @default(PENDING)
  priority OrderPriority         @default(NORMAL)

  totalQuantity Int   @default(0) @map("total_quantity")
  totalCost     Float @default(0) @map("total_cost")

  notes           String?
  requestedBy     String    @map("requested_by")
  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  deliveredAt     DateTime? @map("delivered_at")
  rejectionReason String?   @map("rejection_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store     Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  requester User  @relation("OrderRequester", fields: [requestedBy], references: [id])
  approver  User? @relation("OrderApprover", fields: [approvedBy], references: [id])

  items OrderItem[]

  @@index([storeId])
  @@index([status])
  @@map("orders")
}

// Articles d'une commande d'approvisionnement
model OrderItem {
  id                String   @id @default(cuid())
  orderId           String   @map("order_id")
  productId         String   @map("product_id")
  name              String // Snapshot du nom
  sku               String? // Snapshot du SKU
  requestedQuantity Int      @map("requested_quantity")
  approvedQuantity  Int?     @map("approved_quantity") // Peut être différent de la quantité demandée
  unitCost          Float    @map("unit_cost")
  total             Float
  createdAt         DateTime @default(now()) @map("created_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ============================================================================
// RAPPORTS & ANALYTICS
// ============================================================================

// Type de rapport
enum ReportType {
  SALES // Rapport de ventes
  INVENTORY // Rapport d'inventaire
  DELIVERIES // Rapport de livraisons
  FINANCIAL // Rapport financier
  CUSTOM // Rapport personnalisé
}

// Statut du rapport
enum ReportStatus {
  PENDING // En attente
  GENERATING // En génération
  COMPLETED // Terminé
  FAILED // Échoué
}

// Rapports générés
model Report {
  id          String       @id @default(cuid())
  name        String
  type        ReportType
  status      ReportStatus @default(PENDING)
  parameters  Json? // Paramètres du rapport (période, filtres, etc.)
  result      Json? // Résultat du rapport
  fileUrl     String?      @map("file_url") // URL du fichier PDF/Excel généré
  generatedBy String?      @map("generated_by")
  generatedAt DateTime?    @map("generated_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([type])
  @@index([status])
  @@map("reports")
}

// ============================================================================
// GESTION DU STOCK DES LIVREURS
// ============================================================================

// Stock par livreur et par produit
model DeliveryPersonStock {
  id               String   @id @default(cuid())
  deliveryPersonId String   @map("delivery_person_id")
  productId        String   @map("product_id")
  variantId        String?  @map("variant_id") // Si stock d'une variante spécifique
  quantity         Int      @default(0)
  reserved         Int      @default(0) // Quantité réservée pour commandes en cours
  updatedAt        DateTime @updatedAt @map("updated_at")
  createdAt        DateTime @default(now()) @map("created_at")

  deliveryPerson DeliveryPerson  @relation(fields: [deliveryPersonId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([deliveryPersonId, productId, variantId])
  @@index([deliveryPersonId])
  @@index([productId])
  @@map("delivery_person_stocks")
}

// Mouvements de stock des livreurs
model DeliveryStockMovement {
  id               String                     @id @default(cuid())
  deliveryPersonId String                     @map("delivery_person_id")
  productId        String                     @map("product_id")
  variantId        String?                    @map("variant_id")
  type             DeliveryStockMovementType
  quantity         Int // Quantité (positif ou négatif selon le type)
  storeOrderId     String?                    @map("store_order_id") // Référence à la commande client si c'est une vente
  notes            String?
  createdById      String?                    @map("created_by_id") // Utilisateur qui a créé le mouvement
  createdAt        DateTime                   @default(now()) @map("created_at")

  deliveryPerson DeliveryPerson  @relation(fields: [deliveryPersonId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  storeOrder     StoreOrder?     @relation(fields: [storeOrderId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([deliveryPersonId])
  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@map("delivery_stock_movements")
}

// Tokens de notification push pour les livreurs
model DeliveryPersonPushToken {
  id               String   @id @default(cuid())
  deliveryPersonId String   @map("delivery_person_id")
  token            String   @unique // Token Expo push
  deviceId         String?  @map("device_id") // Identifiant unique du device
  platform         String?  // "ios" ou "android"
  isActive         Boolean  @default(true) @map("is_active")
  lastUsedAt       DateTime @default(now()) @map("last_used_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  deliveryPerson DeliveryPerson @relation(fields: [deliveryPersonId], references: [id], onDelete: Cascade)

  @@index([deliveryPersonId])
  @@index([token])
  @@index([isActive])
  @@map("delivery_person_push_tokens")
}

// Clôtures de journée des livreurs
model DayShift {
  id               String   @id @default(cuid())
  deliveryPersonId String   @map("delivery_person_id")
  date             DateTime @default(now()) // Date de clôture
  commission       Float    @default(0) // Commission totale
  totalOrders      Int      @default(0) @map("total_orders") // Nombre total de commandes
  deliveredOrders  Int      @default(0) @map("delivered_orders") // Livraisons livrées
  cancelledOrders  Int      @default(0) @map("cancelled_orders") // Livraisons annulées
  reportedOrders   Int      @default(0) @map("reported_orders") // Livraisons reportées
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  deliveryPerson DeliveryPerson @relation(fields: [deliveryPersonId], references: [id], onDelete: Cascade)

  @@unique([deliveryPersonId, date])
  @@index([deliveryPersonId])
  @@index([date])
  @@map("day_shifts")
}

