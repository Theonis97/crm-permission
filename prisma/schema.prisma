// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}


enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ItemType {
  PRODUCT
  SERVICE
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
}

enum OpportunityStatus {
  NEW
  IN_PROGRESS
  WON
  LOST
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ContactType {
  PERSONNE
  ENTREPRISE
}

enum ContactStatus {
  PROSPECT
  CLIENT
  LEAD
  ARCHIVE
}

model Contact {
  id          String        @id @default(cuid())
  firstName   String?       @map("first_name")
  lastName    String?       @map("last_name")
  email       String?
  phone       String?
  photo       String?
  job         String?
  description String?
  tags        String[]     

  assignedUserId String       @map("assigned_user_id")
  assignedUser   User         @relation(fields: [assignedUserId], references: [id])
   // tableau de tags
  type        ContactType   @default(PERSONNE)
  status      ContactStatus @default(PROSPECT)

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("contacts")
    quotes   Quote[]
  invoices Invoice[]
  Opportunity Opportunity[]
}

model ProductCategory {
  id             String             @id @default(cuid())
  name           String
  description    String?

  parentId       String?            @map("parent_id")
  parent         ProductCategory?   @relation("Subcategories", fields: [parentId], references: [id])
  subcategories  ProductCategory[]  @relation("Subcategories")

  products       Product[]

  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@map("product_categories")
}

model Product {
  id           String           @id @default(cuid())
  name         String
  description  String?
  photos       String[]         // tableau d’URLs
  prixVente    Float            @map("prix_vente")
  prixAchat    Float            @map("prix_achat")
  tva          Float
  stock        Int              @default(0) // <--- Nouveau champ
  categoryId   String?          @map("category_id")
  category     ProductCategory? @relation(fields: [categoryId], references: [id])

  quoteItems   QuoteItem[]
  invoiceItems InvoiceItem[]

  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@map("products")
  StockMovement StockMovement[]
}

model StockMovement {
  id          String   @id @default(cuid())
  productId   String   @map("product_id")
  quantity    Int      // positif = entrée, négatif = sortie
  type        StockType
  note        String?
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  product     Product  @relation(fields: [productId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
  
  @@map("stock_movements")
}

enum StockType {
  ENTRY
  EXIT
  ADJUSTMENT
  SALE
  RETURN
}

model Quote {
  id            String      @id @default(cuid())
  number        String      @unique
  contactId     String
  status        QuoteStatus @default(DRAFT)
  title         String
  description   String?
  subtotal      Float       @default(0)
  totalDiscount Float       @default(0)
  totalTax      Float       @default(0)
  total         Float       @default(0)
  validUntil    DateTime
  notes         String?
  terms         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  sentAt        DateTime?
  viewedAt      DateTime?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  userId        String

  contact Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items   QuoteItem[]
  invoices Invoice[]

  @@map("quotes")
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  productId   String?
  name        String
  description String?
  quantity    Int      @default(1)
  unitPrice   Float    @default(0)
  discount    Float    @default(0)
  taxRate     Float    @default(20)
  total       Float    @default(0)
  type        ItemType @default(SERVICE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("quote_items")
}

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  contactId     String
  quoteId       String?
  status        InvoiceStatus @default(DRAFT)
  title         String
  description   String?
  subtotal      Float         @default(0)
  totalDiscount Float         @default(0)
  totalTax      Float         @default(0)
  total         Float         @default(0)
  dueDate       DateTime
  paidAt        DateTime?
  notes         String?
  terms         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sentAt        DateTime?
  userId        String

  contact Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  quote   Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items   InvoiceItem[]

  @@map("invoices")
  Opportunity Opportunity[]
}

model InvoiceItem {
  id         String   @id @default(cuid())
  invoiceId  String   @map("invoice_id")
  productId  String   @map("product_id")
  quantity   Int
  unitPrice  Float    @map("unit_price")

  invoice    Invoice  @relation(fields: [invoiceId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

model Opportunity {
  id             String            @id @default(cuid())
  title          String
  description    String?
  status         OpportunityStatus @default(NEW)
  contactId      String            @map("contact_id")
  ownerId        String            @map("owner_id")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  contact        Contact           @relation(fields: [contactId], references: [id])
  owner          User              @relation(fields: [ownerId], references: [id])
  invoices       Invoice[]
  tasks          Task[]
  documents      OpportunityDocument[]
  participants   OpportunityParticipant[]

  @@map("opportunities")
}

model OpportunityDocument {
  id             String       @id @default(cuid())
  opportunityId  String       @map("opportunity_id")
  name           String
  url            String
  uploadedAt     DateTime     @default(now()) @map("uploaded_at")

  opportunity    Opportunity  @relation(fields: [opportunityId], references: [id])

  @@map("opportunity_documents")
}

model OpportunityParticipant {
  id            String       @id @default(cuid())
  opportunityId String       @map("opportunity_id")
  userId        String       @map("user_id")
  addedAt       DateTime     @default(now()) @map("added_at")

  opportunity   Opportunity  @relation(fields: [opportunityId], references: [id])
  user          User         @relation(fields: [userId], references: [id])

  @@unique([opportunityId, userId])
  @@map("opportunity_participants")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  action      ActionType
  entity      String   // nom du modèle concerné, ex: "Contact"
  entityId    String   // ID de l'élément modifié
  description String?  // message facultatif
  payload     Json?    // snapshot des données modifiées
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Task {
  id             String      @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus  @default(TODO)
  userId         String      @map("user_id")
  opportunityId  String?     @map("opportunity_id")
  startDate      DateTime?
  dueDate        DateTime?

  user           User        @relation(fields: [userId], references: [id])
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id])

  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@map("tasks")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String      @unique
  emailVerified DateTime?
  image         String?
  firstName     String?     @map("first_name")
  lastName      String?     @map("last_name")
  password      String?     // Ajout du champ mot de passe
  status        UserStatus  @default(ACTIVE)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  accounts  Account[]
  sessions  Session[]
  userRoles UserRole[]

  quotes   Quote[]
  invoices Invoice[]

  assignedRoles UserRole[] @relation("AssignedBy")

  @@map("users")
  Task Task[]
  OpportunityParticipant OpportunityParticipant[]
  Opportunity Opportunity[]
  AuditLog AuditLog[]
  Contact Contact[]
  StockMovement StockMovement[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  module      String
  action      String
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedBy String?  @map("assigned_by")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner User? @relation("AssignedBy", fields: [assignedBy], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}
