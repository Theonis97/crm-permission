// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ItemType {
  PRODUCT
  SERVICE
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
}

enum OpportunityStatus {
  NEW
  IN_PROGRESS
  WON
  LOST
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ContactType {
  PERSONNE
  ENTREPRISE
}

enum ContactStatus {
  PROSPECT
  CLIENT
  LEAD
  ARCHIVE
}

// ============================================================================
// MODULE COMPTABILITÉ
// ============================================================================

enum ExpenseStatus {
  PENDING          // En attente
  PARTIALLY_PAID   // Payée partiellement
  PAID             // Payée
}

enum ExpensePeriodicity {
  ONCE        // Unique
  WEEKLY      // Hebdomadaire
  MONTHLY     // Mensuelle
  YEARLY      // Annuelle
}

enum ExpensePaymentMode {
  CASH          // Caisse
  BANK          // Banque
  MOBILE_MONEY  // Mobile Money
}

model MyPvitSecret {
  id                    String   @id @default(cuid())
  operation_account_code String
  secret                String
  created_at            DateTime @default(now())
  expires_at            DateTime
  
  @@map("mypvit_secrets")
}

model Contact {
  id          String   @id @default(cuid())
  firstName   String?  @map("first_name")
  lastName    String?  @map("last_name")
  email       String?
  phone       String?
  photo       String?
  job         String?
  description String?
  tags        String[]

  assignedUserId String        @map("assigned_user_id")
  assignedUser   User          @relation(fields: [assignedUserId], references: [id])
  // tableau de tags
  type           ContactType   @default(PERSONNE)
  status         ContactStatus @default(PROSPECT)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  quotes        Quote[]
  invoices      Invoice[]
  opportunities Opportunity[]
  storeContacts StoreContact[]
  storeOrders   StoreOrder[]

  @@map("contacts")
}

model Store {
  id         String   @id @default(cuid())
  name       String
  logo       String?
  coverImage String?  @map("cover_image")
  address    String?
  phone      String?
  email      String?
  whatsapp   String?
  isActive   Boolean  @default(true) @map("is_active")
  managerId  String?  @map("manager_id") // Manager de la boutique (optionnel)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  manager         User?            @relation("StoreManager", fields: [managerId], references: [id], onDelete: SetNull)
  products        StoreProduct[]
  storeOrders     StoreOrder[]
  orders          Order[] // Commandes d'approvisionnement
  deliveryPersons DeliveryPerson[]
  deliveryZones   DeliveryZone[]
  storeContacts   StoreContact[]
  transfersFrom   Transfer[] @relation("fromStore")
  transfersTo     Transfer[] @relation("toStore")
  
  // Relations pour les rôles et permissions magasin
  storeRoles      StoreRole[]
  storeUserRoles  StoreUserRole[]
  
  // Demandes d'approvisionnement
  restockingRequests RestockingRequest[]
  
  // Clôtures de journée
  dayCloses DayClose[]
  
  // SAV - Retours de produits
  productReturns ProductReturn[]
  
  // Sous-caisses
  subBoxes SubBox[]
  
  // Comptabilité - Dépenses liées à ce magasin
  expenses Expense[]
  
  // Recettes journalières
  dailyRevenues DailyRevenue[]

  @@map("stores")
}

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  logo        String?
  website     String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("brands")
}

model ProductCategory {
  id          String  @id @default(cuid())
  name        String
  description String?

  parentId      String?           @map("parent_id")
  parent        ProductCategory?  @relation("Subcategories", fields: [parentId], references: [id])
  subcategories ProductCategory[] @relation("Subcategories")

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_categories")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String?  @unique // Code produit
  description String?
  photos      String[] // tableau d'URLs
  prixVente   Float    @map("prix_vente")
  prixAchat   Float    @map("prix_achat")
  tva         Float    @default(0)
  stock       Int      @default(0)
  minStock    Int      @default(0) @map("min_stock") // Seuil d'alerte stock
  maxStock    Int?     @map("max_stock") // Stock maximum

  // Relations obligatoires et optionnelles
  categoryId String          @map("category_id") // Obligatoire
  category   ProductCategory @relation(fields: [categoryId], references: [id])

  brandId String? @map("brand_id") // Optionnel
  brand   Brand?  @relation(fields: [brandId], references: [id])

  quoteItems              QuoteItem[]
  invoiceItems            InvoiceItem[]
  stockMovements          StockMovement[]
  storeProducts           StoreProduct[]
  warehouseStocks         WarehouseStock[]
  lots                    Lot[]
  transferItems           TransferItem[]
  variants                ProductVariant[]
  storeOrderItems         StoreOrderItem[] // Items des commandes clients
  orderItems              OrderItem[] // Items des commandes d'approvisionnement
  deliveryPersonStocks    DeliveryPersonStock[] // Stock des livreurs
  deliveryStockMovements  DeliveryStockMovement[] // Mouvements de stock des livreurs
  restockingRequestItems  RestockingRequestItem[] // Items des demandes d'approvisionnement
  productReturnItems      ProductReturnItem[] // SAV - Items retournés
  exchangeReturnItems     ProductReturnItem[] @relation("ExchangeProduct") // SAV - Produits donnés en échange

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("products")
}

// Variantes de produits (ex: iPhone 14 Pro - 128GB - Noir)
model ProductVariant {
  id        String  @id @default(cuid())
  productId String  @map("product_id")
  sku       String  @unique // SKU spécifique à la variante
  name      String? // Nom de la variante (ex: "iPhone 14 Pro 128GB Noir")

  // Prix spécifiques à la variante (peut différer du produit parent)
  prixVente Float? @map("prix_vente")
  prixAchat Float? @map("prix_achat")

  // Stock spécifique à la variante
  stock    Int @default(0)
  minStock Int @default(0) @map("min_stock")

  // Attributs de la variante (ex: {color: "Noir", size: "128GB"})
  attributes Json // {attributeName: attributeValue}

  // Images spécifiques à la variante
  images String[] @default([])

  // Poids et dimensions (optionnel)
  weight Float? // en kg
  length Float? // en cm
  width  Float? // en cm
  height Float? // en cm

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product                Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeOrderItems        StoreOrderItem[]
  deliveryPersonStocks   DeliveryPersonStock[] // Stock des livreurs pour cette variante
  deliveryStockMovements DeliveryStockMovement[] // Mouvements de stock des livreurs pour cette variante
  restockingRequestItems RestockingRequestItem[] // Items des demandes d'approvisionnement pour cette variante
  returnedItems          ProductReturnItem[] @relation("ReturnedVariant") // SAV - Variantes retournées
  exchangeReturnItems    ProductReturnItem[] @relation("ExchangeVariant") // SAV - Variantes données en échange

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model StockMovement {
  id        String    @id @default(cuid())
  productId String    @map("product_id")
  quantity  Int // positif = entrée, négatif = sortie
  type      StockType
  note      String?
  userId    String    @map("user_id")
  lotId     String?   @map("lot_id") // Traçabilité par lot
  createdAt DateTime  @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  lot     Lot?    @relation(fields: [lotId], references: [id])

  @@map("stock_movements")
}

enum StockType {
  ENTRY
  EXIT
  ADJUSTMENT
  SALE
  RETURN
  TRANSFER_OUT  // Transfert sortant (vers livreur)
  TRANSFER_IN   // Transfert entrant (depuis entrepôt)
}

enum OrderStatus {
  TOBEVALIDATED // Commande à valider (données incomplètes)
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERING
  DELIVERED
  CANCELLED
  REPORTED
}

enum OrderPriority {
  NORMAL
  HIGH
  URGENT
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DeliveryPersonStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum DeliveryStockMovementType {
  SUPPLY       // Approvisionnement depuis le magasin
  SALE         // Vente à un client
  RETURN       // Retour au magasin
  ADJUSTMENT   // Ajustement de stock
}

// ============================================================================
// POINTAGE - ENUMS
// ============================================================================

enum AttendanceDeviceStatus {
  PENDING   // En attente de validation RH
  APPROVED  // Approuvé
  REVOKED   // Révoqué
}

enum AttendanceTerminalType {
  ENTRY_EXIT  // Entrée/Sortie
  ENTRY_ONLY  // Entrée uniquement
  EXIT_ONLY   // Sortie uniquement
}

enum AttendanceTerminalStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum AttendanceType {
  CHECK_IN   // Entrée
  CHECK_OUT  // Sortie
}

enum AttendanceMethod {
  QR_CODE    // Scan QR
  MANUAL     // Saisie manuelle (RH)
  NFC        // Badge NFC (futur)
  BIOMETRIC  // Biométrie (futur)
}

enum RestockingRequestStatus {
  PENDING      // En attente de validation
  APPROVED     // Approuvée
  REJECTED     // Rejetée
  COMPLETED    // Terminée (stock transféré)
}

// Relation produit-magasin (stock par magasin)
model StoreProduct {
  id         String   @id @default(cuid())
  storeId    String   @map("store_id")
  productId  String   @map("product_id")
  stock      Int      @default(0)
  minStock   Int      @default(0) @map("min_stock")
  maxStock   Int?     @map("max_stock") // Seuil max optionnel
  prixVente  Float?   @map("prix_vente") // Prix de vente spécifique au magasin
  prixAchat  Float?   @map("prix_achat") // Prix d'achat spécifique (optionnel)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId])
  @@map("store_products")
}

// Relation contact-magasin (clients du magasin)
model StoreContact {
  id          String    @id @default(cuid())
  storeId     String    @map("store_id")
  contactId   String    @map("contact_id")
  totalOrders Int       @default(0) @map("total_orders")
  totalSpent  Float     @default(0) @map("total_spent")
  lastOrderAt DateTime? @map("last_order_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([storeId, contactId])
  @@map("store_contacts")
}

// Commandes clients du magasin
model StoreOrder {
  id              String  @id @default(cuid())
  number          String  @unique
  storeId         String  @map("store_id")
  contactId       String? @map("contact_id") // Peut être null pour client walk-in
  customerName    String  @map("customer_name")
  customerPhone   String  @map("customer_phone")
  customerEmail   String? @map("customer_email")
  deliveryAddress String? @map("delivery_address")
  deliveryLatitude  Float?  @map("delivery_latitude")
  deliveryLongitude Float?  @map("delivery_longitude")

  status   OrderStatus   @default(PENDING)
  priority OrderPriority @default(NORMAL)

  subtotal      Float @default(0)
  totalDiscount Float @default(0) @map("total_discount")
  totalTax      Float @default(0) @map("total_tax")
  deliveryFee   Float @default(0) @map("delivery_fee")
  total         Float @default(0)

  paymentMethod PaymentMethod @default(CASH) @map("payment_method")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  paidAt        DateTime?     @map("paid_at")
  
  // Nouveaux champs pour la gestion des paiements en espèces
  amountReceived Float? @map("amount_received") // Montant reçu du client
  changeGiven    Float? @map("change_given")    // Monnaie rendue au client

  deliveryPersonId  String?   @map("delivery_person_id")
  deliveryZoneId    String?   @map("delivery_zone_id")
  requestedDeliveryDate DateTime? @map("requested_delivery_date") // Date de livraison souhaitée par le client
  estimatedDelivery DateTime? @map("estimated_delivery")
  deliveredAt       DateTime? @map("delivered_at")

  notes        String?
  cancelReason String? @map("cancel_reason")
  orderSource  String?  @map("order_source") // Source de la commande (whatsapp, pos, etc.)

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  contact        Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deliveryPerson DeliveryPerson? @relation(fields: [deliveryPersonId], references: [id], onDelete: SetNull)
  deliveryZone   DeliveryZone?   @relation(fields: [deliveryZoneId], references: [id], onDelete: SetNull)
  createdBy      User            @relation(fields: [createdById], references: [id])

  items                  StoreOrderItem[]
  whatsappMessages       WhatsAppMessage[]
  deliveryStockMovements DeliveryStockMovement[] // Mouvements de stock liés à cette commande
  
  // SAV - Retours de produits
  productReturns         ProductReturn[]

  @@map("store_orders")
}

model StoreOrderItem {
  id                String   @id @default(cuid())
  storeOrderId      String   @map("store_order_id")
  productId         String   @map("product_id")
  variantId         String?  @map("variant_id") // Si commande d'une variante spécifique
  name              String // Snapshot du nom au moment de la commande
  sku               String? // Snapshot du SKU
  variantName       String?  @map("variant_name") // Snapshot du nom de la variante
  variantAttributes Json?    @map("variant_attributes") // Snapshot des attributs (couleur, taille, etc.)
  quantity          Int
  unitPrice         Float    @map("unit_price")
  discount          Float    @default(0)
  taxRate           Float    @default(0) @map("tax_rate")
  total             Float
  createdAt         DateTime @default(now()) @map("created_at")

  storeOrder StoreOrder      @relation(fields: [storeOrderId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  
  // SAV - Items retournés
  productReturnItems ProductReturnItem[]

  @@map("store_order_items")
}

// Commandes WhatsApp avec erreurs de produits
model FailedWhatsAppOrder {
  id                String    @id @default(cuid())
  rawMessage        String    @db.Text // Message WhatsApp original
  senderId          String?   @map("sender_id") // ID WhatsApp du vendeur
  senderPhone       String?   @map("sender_phone") // Téléphone du vendeur
  timestamp         DateTime? // Timestamp du message original
  
  // Données extraites
  customerName      String?   @map("customer_name")
  customerPhone     String?   @map("customer_phone")
  deliveryAddress   String?   @map("delivery_address")
  totalAmount       Float?    @map("total_amount")
  
  // Produits demandés (JSON)
  requestedProducts Json      @map("requested_products") // Liste des produits avec leurs codes
  
  // Erreur détaillée
  errorType         String    @map("error_type") // "PRODUCT_NOT_FOUND", "MULTIPLE_ERRORS", etc.
  errorDetails      String    @db.Text @map("error_details") // Description détaillée
  missingProducts   Json      @map("missing_products") // Liste des codes produits non trouvés
  
  // Statut de traitement
  status            String    @default("PENDING") // PENDING, RESOLVED, REJECTED
  resolvedAt        DateTime? @map("resolved_at")
  resolvedBy        String?   @map("resolved_by") // User ID qui a résolu
  resolvedOrderId   String?   @map("resolved_order_id") // ID de la commande créée si résolu
  resolutionNotes   String?   @db.Text @map("resolution_notes")
  
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  
  resolvedByUser    User?     @relation(fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([customerPhone])
  @@index([createdAt])
  @@map("failed_whatsapp_orders")
}

// Livreurs
model DeliveryPerson {
  id              String               @id @default(cuid())
  storeId         String               @map("store_id")
  name            String
  phone           String               @unique // Obligatoire et unique
  email           String               @unique // Obligatoire et unique
  password        String // Mot de passe hashé (par défaut "password" sera défini lors de la création)
  avatar          String?
  vehicle         String? // Type de véhicule
  plateNumber     String?              @map("plate_number") // Plaque d'immatriculation
  status          DeliveryPersonStatus @default(AVAILABLE)
  rating          Float? // Note moyenne
  totalDeliveries Int                  @default(0) @map("total_deliveries")
  isActive        Boolean              @default(true) @map("is_active")
  
  // Réinitialisation de mot de passe
  resetPasswordToken       String?              @map("reset_password_token")
  resetPasswordTokenExpiry DateTime?            @map("reset_password_token_expiry")
  resetPasswordCode        String?              @map("reset_password_code") // Code à 6 chiffres
  resetPasswordCodeExpiry  DateTime?            @map("reset_password_code_expiry") // Expiration du code
  
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  store               Store                    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeOrders         StoreOrder[]
  wallet              CourierWallet?
  deliveryZones       DeliveryZone[] // Zones assignées au livreur
  stock               DeliveryPersonStock[] // Stock du livreur
  stockMovements      DeliveryStockMovement[] // Mouvements de stock du livreur
  pushTokens          DeliveryPersonPushToken[] // Tokens de notification push
  dayShifts           DayShift[] // Clôtures de journée
  restockingRequests  RestockingRequest[] // Demandes d'approvisionnement
  notifications       DeliveryNotification[] // Notifications du livreur

  @@map("delivery_persons")
}

// Zones de livraison
model DeliveryZone {
  id               String   @id @default(cuid())
  storeId          String   @map("store_id")
  name             String
  color            String   @default("#3B82F6") // Couleur pour la carte
  coverage         String? // Description de la couverture
  coordinates      Json // Array de {lat, lng} pour le polygone
  centerLatitude   Float?   @map("center_latitude") // Centre de la zone (calculé)
  centerLongitude  Float?   @map("center_longitude")
  deliveryFee      Float    @default(0) @map("delivery_fee")
  estimatedTime    Int?     @map("estimated_time") // Temps de livraison estimé en minutes
  isActive         Boolean  @default(true) @map("is_active")
  deliveryPersonId String?  @map("delivery_person_id") // Livreur assigné
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deliveryPerson DeliveryPerson? @relation(fields: [deliveryPersonId], references: [id], onDelete: SetNull)
  storeOrders    StoreOrder[]

  @@map("delivery_zones")
}

model Quote {
  id            String      @id @default(cuid())
  number        String      @unique
  contactId     String
  status        QuoteStatus @default(DRAFT)
  title         String
  description   String?
  subtotal      Float       @default(0)
  totalDiscount Float       @default(0)
  totalTax      Float       @default(0)
  total         Float       @default(0)
  validUntil    DateTime
  notes         String?
  terms         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  sentAt        DateTime?
  viewedAt      DateTime?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  userId        String

  contact  Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    QuoteItem[]
  invoices Invoice[]

  @@map("quotes")
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  productId   String?
  name        String
  description String?
  quantity    Int      @default(1)
  unitPrice   Float    @default(0)
  discount    Float    @default(0)
  taxRate     Float    @default(20)
  total       Float    @default(0)
  type        ItemType @default(SERVICE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("quote_items")
}

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  contactId     String
  quoteId       String?
  status        InvoiceStatus @default(DRAFT)
  title         String
  description   String?
  subtotal      Float         @default(0)
  totalDiscount Float         @default(0)
  totalTax      Float         @default(0)
  total         Float         @default(0)
  dueDate       DateTime
  paidAt        DateTime?
  notes         String?
  terms         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sentAt        DateTime?
  userId        String

  contact     Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  quote       Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       InvoiceItem[]
  Opportunity Opportunity[]

  @@map("invoices")
}

model InvoiceItem {
  id        String @id @default(cuid())
  invoiceId String @map("invoice_id")
  productId String @map("product_id")
  quantity  Int
  unitPrice Float  @map("unit_price")

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

model Opportunity {
  id               String            @id @default(cuid())
  title            String
  description      String?
  status           OpportunityStatus @default(NEW)
  globalAmount     Float?            @map("global_amount")
  finalAmount      Float?            @map("final_amount")
  contactId        String            @map("contact_id")
  ownerId          String            @map("owner_id")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  contact      Contact                  @relation(fields: [contactId], references: [id])
  owner        User                     @relation(fields: [ownerId], references: [id])
  invoices     Invoice[]
  tasks        Task[]
  documents    OpportunityDocument[]
  participants OpportunityParticipant[]

  @@map("opportunities")
}

model OpportunityDocument {
  id            String   @id @default(cuid())
  opportunityId String   @map("opportunity_id")
  name          String
  url           String
  uploadedAt    DateTime @default(now()) @map("uploaded_at")

  opportunity Opportunity @relation(fields: [opportunityId], references: [id])

  @@map("opportunity_documents")
}

model OpportunityParticipant {
  id            String   @id @default(cuid())
  opportunityId String   @map("opportunity_id")
  userId        String   @map("user_id")
  addedAt       DateTime @default(now()) @map("added_at")

  opportunity Opportunity @relation(fields: [opportunityId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@unique([opportunityId, userId])
  @@map("opportunity_participants")
}

model AuditLog {
  id          String     @id @default(cuid())
  userId      String     @map("user_id")
  action      ActionType
  entity      String // nom du modèle concerné, ex: "Contact"
  entityId    String // ID de l'élément modifié
  description String? // message facultatif
  payload     Json? // snapshot des données modifiées
  createdAt   DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Task {
  id            String     @id @default(cuid())
  title         String
  description   String?
  status        TaskStatus @default(TODO)
  isImportant   Boolean    @default(false) @map("is_important")
  userId        String     @map("user_id")
  opportunityId String?    @map("opportunity_id")
  startDate     DateTime?
  dueDate       DateTime?

  user        User         @relation(fields: [userId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tasks")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  firstName     String?    @map("first_name")
  lastName      String?    @map("last_name")
  password      String? // Ajout du champ mot de passe
  status        UserStatus @default(ACTIVE)
  matricule     String?    @unique // Matricule employé pour le pointage
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  accounts  Account[]
  sessions  Session[]
  userRoles UserRole[]

  quotes   Quote[]
  invoices Invoice[]

  assignedRoles             UserRole[]               @relation("AssignedBy")
  tasks                     Task[]
  opportunityParticipants   OpportunityParticipant[]
  opportunities             Opportunity[]
  auditLogs         AuditLog[]
  contacts               Contact[]
  stockMovements         StockMovement[]
  storeOrders            StoreOrder[]
  managedStores          Store[]                   @relation("StoreManager")
  managedWarehouses      Warehouse[]
  requestedOrders        Order[]                   @relation("OrderRequester")
  approvedOrders         Order[]                   @relation("OrderApprover")
  deliveryStockMovements DeliveryStockMovement[] // Mouvements de stock des livreurs créés par cet utilisateur
  resolvedFailedOrders   FailedWhatsAppOrder[] // Commandes WhatsApp avec erreurs résolues par cet utilisateur
  pwaPushSubscription    PWAPushSubscription? // Subscription PWA pour les notifications push
  
  // Relations pour les rôles et permissions magasin
  storeUserRoles         StoreUserRole[]
  assignedStoreRoles     StoreUserRole[] @relation("StoreRoleAssignedBy")
  
  // Demandes d'approvisionnement approuvées
  approvedRestockingRequests RestockingRequest[]
  
  // Clôtures de journée effectuées
  dayCloses DayClose[]
  
  // SAV - Retours de produits
  processedProductReturns ProductReturn[] @relation("ProductReturnProcessor")
  createdProductReturns   ProductReturn[] @relation("ProductReturnCreator")
  sentToCashierReturns    ProductReturn[] @relation("ProductReturnSentToCashier")
  cashierValidatedReturns ProductReturn[] @relation("ProductReturnCashierValidator")
  
  // Pointage - Relations
  attendanceDevices         AttendanceDevice[] // Appareils autorisés pour le pointage
  approvedAttendanceDevices AttendanceDevice[] @relation("DeviceApprover") // Appareils approuvés par cet utilisateur
  attendanceLogs            AttendanceLog[] // Historique des pointages
  usedQRTokens              AttendanceQRToken[] // Tokens QR utilisés
  
  // Comptabilité - Relations
  createdExpenses           Expense[]          @relation("ExpenseCreator")
  expensePayments           ExpensePayment[]   @relation("ExpensePaymentPayer")
  createdDailyRevenues      DailyRevenue[]     @relation("DailyRevenueCreatedBy")
  accountingAccessCodes     AccountingAccessCode[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  module      String
  action      String
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedBy String?  @map("assigned_by")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner User? @relation("AssignedBy", fields: [assignedBy], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================================
// RÔLES ET PERMISSIONS AU NIVEAU MAGASIN
// ============================================================================

model StoreRole {
  id          String   @id @default(cuid())
  name        String   // Ex: "Manager", "Vendeur", "Caissier"
  description String?
  storeId     String   @map("store_id")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  store                Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeUserRoles       StoreUserRole[]
  storeRolePermissions StoreRolePermission[]

  @@unique([name, storeId])
  @@map("store_roles")
}

model StorePermission {
  id          String   @id @default(cuid())
  name        String   @unique // Ex: "store.products.view", "store.pos.access"
  description String?
  module      String   // Ex: "products", "pos", "orders"
  action      String   // Ex: "view", "create", "edit", "delete"
  createdAt   DateTime @default(now()) @map("created_at")

  storeRolePermissions StoreRolePermission[]

  @@map("store_permissions")
}

model StoreUserRole {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  storeId    String   @map("store_id")
  roleId     String   @map("role_id")
  assignedBy String   @map("assigned_by")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  store          Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  role           StoreRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedByUser User      @relation("StoreRoleAssignedBy", fields: [assignedBy], references: [id])

  @@unique([userId, storeId, roleId])
  @@map("store_user_roles")
}

model StoreRolePermission {
  id           String   @id @default(cuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       StoreRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission StorePermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("store_role_permissions")
}

// ============================================================================
// LOGISTIQUE & ENTREPÔTS
// ============================================================================

// Entrepôt central
model Warehouse {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  phone     String?
  managerId String?  @map("manager_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  manager       User?            @relation(fields: [managerId], references: [id])
  stocks        WarehouseStock[]
  transfersFrom Transfer[]       @relation("fromWarehouse")
  transfersTo   Transfer[]       @relation("toWarehouse")

  @@map("warehouses")
}

// Stock par entrepôt
model WarehouseStock {
  id          String   @id @default(cuid())
  warehouseId String   @map("warehouse_id")
  productId   String   @map("product_id")
  quantity    Int      @default(0)
  reserved    Int      @default(0) // Quantité réservée pour commandes en cours
  updatedAt   DateTime @updatedAt @map("updated_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@map("warehouse_stocks")
}

// Statuts des transferts
enum TransferStatus {
  PENDING // En attente
  IN_PROGRESS // En cours
  COMPLETED // Terminé
  CANCELLED // Annulé
}

// Transferts entre entrepôts ou magasins
model Transfer {
  id              String         @id @default(cuid())
  code            String         @unique
  fromWarehouseId String?        @map("from_warehouse_id")
  toWarehouseId   String?        @map("to_warehouse_id")
  fromStoreId     String?        @map("from_store_id")
  toStoreId       String?        @map("to_store_id")
  status          TransferStatus @default(PENDING)
  scheduledAt     DateTime?      @map("scheduled_at")
  completedAt     DateTime?      @map("completed_at")
  notes           String?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  items         TransferItem[]
  fromWarehouse Warehouse?     @relation("fromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse?     @relation("toWarehouse", fields: [toWarehouseId], references: [id])
  fromStore     Store?         @relation("fromStore", fields: [fromStoreId], references: [id])
  toStore       Store?         @relation("toStore", fields: [toStoreId], references: [id])

  @@map("transfers")
}

// Articles dans un transfert
model TransferItem {
  id               String @id @default(cuid())
  transferId       String @map("transfer_id")
  productId        String @map("product_id")
  quantity         Int
  quantityReceived Int?   @map("quantity_received") // Quantité réellement reçue

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("transfer_items")
}

// Lots et dates de péremption
model Lot {
  id            String    @id @default(cuid())
  lotNumber     String    @unique
  productId     String    @map("product_id")
  quantityTotal Int       @map("quantity_total")
  expiryDate    DateTime? @map("expiry_date")
  createdAt     DateTime  @default(now()) @map("created_at")

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@map("lots")
}

// ============================================================================
// GESTION LIVREURS & PORTEFEUILLE
// ============================================================================

// Portefeuille du livreur
model CourierWallet {
  id            String   @id @default(cuid())
  courierId     String   @unique @map("courier_id")
  balance       Float    @default(0)
  currency      String   @default("XAF") // FCFA
  lastUpdatedAt DateTime @updatedAt @map("last_updated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  courier      DeliveryPerson       @relation(fields: [courierId], references: [id], onDelete: Cascade)
  transactions CourierTransaction[]

  @@map("courier_wallets")
}

// Type de transaction livreur
enum TransactionType {
  CREDIT // Crédit (paiement reçu)
  DEBIT // Débit (retrait, commission)
}

// Transactions du portefeuille livreur
model CourierTransaction {
  id          String          @id @default(cuid())
  walletId    String          @map("wallet_id")
  type        TransactionType
  amount      Float
  description String?
  reference   String? // Référence de la commande ou transaction
  createdAt   DateTime        @default(now()) @map("created_at")

  wallet CourierWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("courier_transactions")
}

// ============================================================================
// INTÉGRATION WHATSAPP
// ============================================================================

// Statuts des messages WhatsApp
enum WhatsAppMessageStatus {
  NEW // Nouveau
  PROCESSING // En traitement
  PROCESSED // Traité
  REPLIED // Répondu
  FAILED // Échoué
  IGNORED // Ignoré
}

// Messages WhatsApp reçus/envoyés
model WhatsAppMessage {
  id           String                @id @default(cuid())
  waId         String                @unique @map("wa_id") // WhatsApp message ID
  fromPhone    String                @map("from_phone")
  toPhone      String?               @map("to_phone")
  content      String                @db.Text
  messageType  String                @default("text") @map("message_type") // text, image, audio, etc.
  status       WhatsAppMessageStatus @default(NEW)
  storeOrderId String?               @map("store_order_id")
  processedAt  DateTime?             @map("processed_at")
  errorMessage String?               @map("error_message") @db.Text
  createdAt    DateTime              @default(now()) @map("created_at")

  storeOrder StoreOrder? @relation(fields: [storeOrderId], references: [id])

  @@index([fromPhone])
  @@index([status])
  @@map("whatsapp_messages")
}

// ============================================================================
// COMMANDES D'APPROVISIONNEMENT (RESTOCKING)
// ============================================================================

// Statut de la commande d'approvisionnement
enum RestockingOrderStatus {
  PENDING // En attente de validation
  APPROVED // Approuvée
  PREPARING // En préparation
  SHIPPED // Expédiée
  DELIVERED // Livrée
  CANCELLED // Annulée
  REJECTED // Rejetée
}

// Commandes d'approvisionnement (store vers entrepôt)
model Order {
  id       String                @id @default(cuid())
  number   String                @unique
  storeId  String                @map("store_id")
  status   RestockingOrderStatus @default(PENDING)
  priority OrderPriority         @default(NORMAL)

  totalQuantity Int   @default(0) @map("total_quantity")
  totalCost     Float @default(0) @map("total_cost")

  notes           String?
  requestedBy     String    @map("requested_by")
  approvedBy      String?   @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  deliveredAt     DateTime? @map("delivered_at")
  rejectionReason String?   @map("rejection_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store     Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  requester User  @relation("OrderRequester", fields: [requestedBy], references: [id])
  approver  User? @relation("OrderApprover", fields: [approvedBy], references: [id])

  items OrderItem[]

  @@index([storeId])
  @@index([status])
  @@map("orders")
}

// Articles d'une commande d'approvisionnement
model OrderItem {
  id                String   @id @default(cuid())
  orderId           String   @map("order_id")
  productId         String   @map("product_id")
  name              String // Snapshot du nom
  sku               String? // Snapshot du SKU
  requestedQuantity Int      @map("requested_quantity")
  approvedQuantity  Int?     @map("approved_quantity") // Peut être différent de la quantité demandée
  unitCost          Float    @map("unit_cost")
  total             Float
  createdAt         DateTime @default(now()) @map("created_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ============================================================================
// RAPPORTS & ANALYTICS
// ============================================================================

// Type de rapport
enum ReportType {
  SALES // Rapport de ventes
  INVENTORY // Rapport d'inventaire
  DELIVERIES // Rapport de livraisons
  FINANCIAL // Rapport financier
  CUSTOM // Rapport personnalisé
}

// Statut du rapport
enum ReportStatus {
  PENDING // En attente
  GENERATING // En génération
  COMPLETED // Terminé
  FAILED // Échoué
}

// Rapports générés
model Report {
  id          String       @id @default(cuid())
  name        String
  type        ReportType
  status      ReportStatus @default(PENDING)
  parameters  Json? // Paramètres du rapport (période, filtres, etc.)
  result      Json? // Résultat du rapport
  fileUrl     String?      @map("file_url") // URL du fichier PDF/Excel généré
  generatedBy String?      @map("generated_by")
  generatedAt DateTime?    @map("generated_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([type])
  @@index([status])
  @@map("reports")
}

// ============================================================================
// GESTION DU STOCK DES LIVREURS
// ============================================================================

// Stock par livreur et par produit
model DeliveryPersonStock {
  id               String   @id @default(cuid())
  deliveryPersonId String   @map("delivery_person_id")
  productId        String   @map("product_id")
  variantId        String?  @map("variant_id") // Si stock d'une variante spécifique
  quantity         Int      @default(0)
  reserved         Int      @default(0) // Quantité réservée pour commandes en cours
  updatedAt        DateTime @updatedAt @map("updated_at")
  createdAt        DateTime @default(now()) @map("created_at")

  deliveryPerson DeliveryPerson  @relation(fields: [deliveryPersonId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([deliveryPersonId, productId, variantId])
  @@index([deliveryPersonId])
  @@index([productId])
  @@map("delivery_person_stocks")
}

// Mouvements de stock des livreurs
model DeliveryStockMovement {
  id               String                     @id @default(cuid())
  deliveryPersonId String                     @map("delivery_person_id")
  productId        String                     @map("product_id")
  variantId        String?                    @map("variant_id")
  type             DeliveryStockMovementType
  quantity         Int // Quantité (positif ou négatif selon le type)
  storeOrderId     String?                    @map("store_order_id") // Référence à la commande client si c'est une vente
  notes            String?
  createdById      String?                    @map("created_by_id") // Utilisateur qui a créé le mouvement
  createdAt        DateTime                   @default(now()) @map("created_at")

  deliveryPerson DeliveryPerson  @relation(fields: [deliveryPersonId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  storeOrder     StoreOrder?     @relation(fields: [storeOrderId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([deliveryPersonId])
  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@map("delivery_stock_movements")
}

// Tokens de notification push pour les livreurs
model DeliveryPersonPushToken {
  id               String   @id @default(cuid())
  deliveryPersonId String   @map("delivery_person_id")
  token            String   @unique // Token Expo push
  deviceId         String?  @map("device_id") // Identifiant unique du device
  platform         String?  // "ios" ou "android"
  isActive         Boolean  @default(true) @map("is_active")
  lastUsedAt       DateTime @default(now()) @map("last_used_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  deliveryPerson DeliveryPerson @relation(fields: [deliveryPersonId], references: [id], onDelete: Cascade)

  @@index([deliveryPersonId])
  @@index([token])
  @@index([isActive])
  @@map("delivery_person_push_tokens")
}

// Clôtures de journée des livreurs
model DayShift {
  id               String   @id @default(cuid())
  deliveryPersonId String   @map("delivery_person_id")
  date             DateTime @default(now()) // Date de clôture
  commission       Float    @default(0) // Commission totale
  totalOrders      Int      @default(0) @map("total_orders") // Nombre total de commandes
  deliveredOrders  Int      @default(0) @map("delivered_orders") // Livraisons livrées
  cancelledOrders  Int      @default(0) @map("cancelled_orders") // Livraisons annulées
  reportedOrders   Int      @default(0) @map("reported_orders") // Livraisons reportées
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  deliveryPerson DeliveryPerson @relation(fields: [deliveryPersonId], references: [id], onDelete: Cascade)

  @@unique([deliveryPersonId, date])
  @@index([deliveryPersonId])
  @@index([date])
  @@map("day_shifts")
}

// Notifications pour les livreurs
enum NotificationType {
  ORDER      // Notification de commande
  SYSTEM     // Notification système
  INFO       // Notification informative
}

model DeliveryNotification {
  id               String           @id @default(cuid())
  deliveryPersonId String           @map("delivery_person_id")
  title            String
  body             String
  type             NotificationType @default(INFO)
  isRead           Boolean          @default(false) @map("is_read")
  data             Json?            // Données additionnelles (orderId, zoneId, etc.)
  createdAt        DateTime         @default(now()) @map("created_at")
  readAt           DateTime?        @map("read_at")

  deliveryPerson DeliveryPerson @relation(fields: [deliveryPersonId], references: [id], onDelete: Cascade)

  @@index([deliveryPersonId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@map("delivery_notifications")
}

// Subscriptions PWA pour les notifications push
model PWAPushSubscription {
  id         String   @id @default(cuid())
  userId     String   @unique @map("user_id") // ID de l'utilisateur (livreur)
  endpoint   String   // URL de l'endpoint push
  p256dhKey  String   @map("p256dh_key") // Clé publique pour le chiffrement
  authKey    String   @map("auth_key") // Clé d'authentification
  userAgent  String?  @map("user_agent") // Navigateur utilisé
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([createdAt])
  @@map("pwa_push_subscriptions")
}

// ============================================================================
// DEMANDES D'APPROVISIONNEMENT LIVREURS
// ============================================================================

// Demande d'approvisionnement d'un livreur
model RestockingRequest {
  id               String                 @id @default(cuid())
  deliveryPersonId String                 @map("delivery_person_id")
  storeId          String                 @map("store_id")
  status           RestockingRequestStatus @default(PENDING)
  notes            String?                // Notes du livreur
  rejectionReason  String?                @map("rejection_reason") // Raison du rejet
  approvedById     String?                @map("approved_by_id") // Utilisateur qui a approuvé
  approvedAt       DateTime?              @map("approved_at")
  completedAt      DateTime?              @map("completed_at")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  deliveryPerson DeliveryPerson        @relation(fields: [deliveryPersonId], references: [id], onDelete: Cascade)
  store          Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  approvedBy     User?                 @relation(fields: [approvedById], references: [id], onDelete: SetNull)
  items          RestockingRequestItem[] // Items demandés

  @@index([deliveryPersonId])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
  @@map("restocking_requests")
}

// Items d'une demande d'approvisionnement
model RestockingRequestItem {
  id                 String   @id @default(cuid())
  restockingRequestId String   @map("restocking_request_id")
  productId          String   @map("product_id")
  variantId          String?  @map("variant_id")
  requestedQuantity  Int      @map("requested_quantity") // Quantité demandée
  approvedQuantity   Int?     @map("approved_quantity")  // Quantité approuvée (peut être différente)
  notes              String?  // Notes spécifiques à cet item

  restockingRequest RestockingRequest @relation(fields: [restockingRequestId], references: [id], onDelete: Cascade)
  product           Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant           ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([restockingRequestId, productId, variantId])
  @@index([restockingRequestId])
  @@index([productId])
  @@map("restocking_request_items")
}

// Clôture de journée de caisse
model DayClose {
  id            String   @id @default(cuid())
  storeId       String   @map("store_id")
  userId        String   @map("user_id")
  closeDate     DateTime @map("close_date") // Date de la journée clôturée (sans heure)
  totalSales    Int      @map("total_sales") // Nombre de ventes
  totalItems    Int      @map("total_items") // Nombre total d'articles vendus
  subtotal      Float    @map("subtotal") // Sous-total avant TVA et remises
  totalTax      Float    @map("total_tax") // Total TVA
  totalDiscounts Float   @map("total_discounts") // Total des remises accordées
  totalRevenue  Float    @map("total_revenue") // Recette totale encaissée
  notes         String?  // Notes optionnelles de clôture
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, closeDate]) // Une seule clôture par magasin par jour
  @@index([storeId])
  @@index([userId])
  @@index([closeDate])
  @@map("day_closes")
}

// Recette journalière d'un magasin (agrégation des clôtures + dépenses + recette comptée)
model DailyRevenue {
  id              String   @id @default(cuid())
  storeId         String   @map("store_id")
  date            DateTime // Date du jour (sans heure)
  
  // Données calculées/agrégées
  totalDayCloses  Float    @default(0) @map("total_day_closes")  // Somme des clôtures de caisse du jour
  totalExpenses   Float    @default(0) @map("total_expenses")    // Somme des dépenses du magasin ce jour
  
  // Données saisies manuellement
  countedRevenue  Float?   @map("counted_revenue")  // Recette comptée (saisie manuelle)
  
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdById     String?  @map("created_by_id")

  store     Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("DailyRevenueCreatedBy", fields: [createdById], references: [id])

  @@unique([storeId, date]) // Un seul enregistrement par magasin par jour
  @@index([storeId])
  @@index([date])
  @@map("daily_revenues")
}

// ============================================================================
// SERVICE APRÈS-VENTE (SAV)
// ============================================================================

// Motif de retour d'un produit
enum ProductReturnReason {
  DEFECTIVE       // Défectueux
  BROKEN          // Cassé
  NOT_SATISFIED   // Pas satisfait
  NON_FUNCTIONAL  // Non fonctionnel
  WRONG_PRODUCT   // Mauvais produit livré
  EXPIRED         // Produit périmé
  QUALITY_ISSUE   // Problème de qualité
  OTHER           // Autre
}

// État/Condition du produit retourné
enum ProductCondition {
  NEW             // Neuf (emballage intact)
  GOOD            // Bon état
  USED            // Utilisé
  DAMAGED         // Endommagé
  DEFECTIVE       // Défectueux
}

// Statut du retour
enum ProductReturnStatus {
  PENDING           // En attente de traitement SAV
  APPROVED          // Approuvé par SAV (en attente de décision échange/remboursement)
  AWAITING_CASHIER  // Envoyé à la caisse, en attente de validation
  REFUNDED          // Remboursé (validé par caisse)
  EXCHANGED         // Échangé (validé par caisse si ajout requis)
  REJECTED          // Rejeté
}

// Type de résolution SAV
enum SAVResolutionType {
  EXCHANGE    // Échange de produit
  REFUND      // Remboursement
}

// Retour de produit (peut être lié ou non à une commande)
model ProductReturn {
  id              String              @id @default(cuid())
  number          String              @unique // Numéro de retour (ex: RET-20231215-001)
  trackingNumber  String?             @unique @map("tracking_number") // Numéro de suivi SAV (ex: SAV-20231215-001)
  storeId         String              @map("store_id")
  storeOrderId    String?             @map("store_order_id") // Optionnel - peut ne pas être lié à une commande
  
  // Informations client (optionnelles si pas de commande liée)
  customerName    String?             @map("customer_name")
  customerPhone   String?             @map("customer_phone")
  
  // Statut et résolution
  status          ProductReturnStatus @default(PENDING)
  resolutionType  SAVResolutionType?  @map("resolution_type") // Type de résolution choisi
  resolution      String?             // Notes sur la résolution
  
  // Montants
  totalRefundAmount   Float           @default(0) @map("total_refund_amount") // Montant total remboursé
  totalCustomerAddition Float         @default(0) @map("total_customer_addition") // Montant total à payer par le client (échange)
  totalDiscount       Float           @default(0) @map("total_discount") // Rabais total accordé par SAV
  
  // Commande SubBox SAV créée pour l'échange
  savSubBoxOrderId    String?         @unique @map("sav_sub_box_order_id")
  
  // Traitement SAV
  processedById   String?             @map("processed_by_id")
  processedAt     DateTime?           @map("processed_at")
  
  // Envoi à la caisse
  sentToCashier       Boolean         @default(false) @map("sent_to_cashier")
  sentToCashierAt     DateTime?       @map("sent_to_cashier_at")
  sentToCashierById   String?         @map("sent_to_cashier_by_id")
  
  // Validation par la caisse
  cashierValidated    Boolean         @default(false) @map("cashier_validated")
  cashierValidatedAt  DateTime?       @map("cashier_validated_at")
  cashierValidatedById String?        @map("cashier_validated_by_id")
  
  // Notes
  notes           String?
  
  createdById     String              @map("created_by_id")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  // Relations
  store           Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeOrder      StoreOrder?         @relation(fields: [storeOrderId], references: [id], onDelete: Cascade)
  savSubBoxOrder  SubBoxOrder?        @relation("SAVSubBoxOrder", fields: [savSubBoxOrderId], references: [id], onDelete: SetNull)
  processedBy     User?               @relation("ProductReturnProcessor", fields: [processedById], references: [id], onDelete: SetNull)
  sentToCashierBy User?               @relation("ProductReturnSentToCashier", fields: [sentToCashierById], references: [id], onDelete: SetNull)
  cashierValidatedBy User?            @relation("ProductReturnCashierValidator", fields: [cashierValidatedById], references: [id], onDelete: SetNull)
  createdBy       User                @relation("ProductReturnCreator", fields: [createdById], references: [id])
  
  // Items retournés
  items           ProductReturnItem[]

  @@index([storeId])
  @@index([storeOrderId])
  @@index([status])
  @@index([trackingNumber])
  @@index([sentToCashier])
  @@index([createdAt])
  @@map("product_returns")
}

// Item retourné (un produit spécifique du retour)
model ProductReturnItem {
  id                String              @id @default(cuid())
  productReturnId   String              @map("product_return_id")
  productId         String              @map("product_id")
  variantId         String?             @map("variant_id") // Variante du produit retourné
  storeOrderItemId  String?             @map("store_order_item_id") // Optionnel - lien vers l'item de la commande originale
  
  // Informations produit (snapshot)
  productName       String              @map("product_name")
  productSku        String?             @map("product_sku")
  
  // Quantité et prix
  quantity          Int                 // Quantité retournée
  unitPrice         Float               @map("unit_price") // Prix unitaire du produit
  refundAmount      Float               @default(0) @map("refund_amount") // Montant remboursé pour cet item
  
  // État du produit retourné
  condition         ProductCondition    @default(GOOD) // État/condition du produit
  
  // Motif du retour
  reason            ProductReturnReason
  reasonDetails     String?             @map("reason_details") // Détails supplémentaires du motif
  
  // Résolution spécifique à cet item
  isRefunded        Boolean             @default(false) @map("is_refunded") // true = remboursé, false = échangé
  
  // Informations d'échange (si isRefunded = false)
  exchangeProductId       String?       @map("exchange_product_id") // Produit donné en échange
  exchangeProductVariantId String?      @map("exchange_product_variant_id") // Variante du produit d'échange
  exchangeProductName     String?       @map("exchange_product_name") // Nom du produit d'échange (snapshot)
  exchangeProductPrice    Float?        @map("exchange_product_price") // Prix du produit d'échange
  exchangeDiscount        Float         @default(0) @map("exchange_discount") // Rabais accordé par SAV
  customerAddition        Float         @default(0) @map("customer_addition") // Montant à payer par le client (prix échange - prix retour - rabais)
  
  createdAt         DateTime            @default(now()) @map("created_at")

  // Relations
  productReturn     ProductReturn       @relation(fields: [productReturnId], references: [id], onDelete: Cascade)
  product           Product             @relation(fields: [productId], references: [id])
  variant           ProductVariant?     @relation("ReturnedVariant", fields: [variantId], references: [id])
  storeOrderItem    StoreOrderItem?     @relation(fields: [storeOrderItemId], references: [id])
  exchangeProduct   Product?            @relation("ExchangeProduct", fields: [exchangeProductId], references: [id])
  exchangeVariant   ProductVariant?     @relation("ExchangeVariant", fields: [exchangeProductVariantId], references: [id])

  @@index([productReturnId])
  @@index([productId])
  @@index([exchangeProductId])
  @@map("product_return_items")
}

// ============================================================================
// SOUS-CAISSES (SUB-BOXES) - Pour accélérer le processus de vente
// ============================================================================

// Statut d'une commande de sous-caisse
enum SubBoxOrderStatus {
  PENDING   // En attente - le client est encore avec la sous-caisse
  VALIDATED // Validée - la caisse principale a validé et encaissé
  CANCELLED // Annulée
}

// Sous-caisse d'un magasin
model SubBox {
  id          String   @id @default(cuid())
  storeId     String   @map("store_id")
  name        String   // Prénom de l'opérateur de la sous-caisse
  code        String   // Code unique de la sous-caisse (ex: "SC01", "SC02")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  store       Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders      SubBoxOrder[] // Commandes créées par cette sous-caisse

  @@unique([storeId, code]) // Code unique par magasin
  @@index([storeId])
  @@index([isActive])
  @@map("sub_boxes")
}

// Commande créée par une sous-caisse
model SubBoxOrder {
  id           String            @id @default(cuid())
  subBoxId     String            @map("sub_box_id")
  storeId      String            @map("store_id")
  clientCode   String            @map("client_code") // Code unique donné au client (ex: "A001", "B042")
  status       SubBoxOrderStatus @default(PENDING)
  
  // Totaux calculés
  subtotal     Float             @default(0)
  totalDiscount Float            @default(0) @map("total_discount")
  totalItems   Int               @default(0) @map("total_items")
  
  // Notes optionnelles
  notes        String?
  
  // Validation par la caisse principale
  validatedAt  DateTime?         @map("validated_at")
  cancelledAt  DateTime?         @map("cancelled_at")
  cancelReason String?           @map("cancel_reason")
  
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  subBox       SubBox            @relation(fields: [subBoxId], references: [id], onDelete: Cascade)
  items        SubBoxOrderItem[] // Produits de la commande
  
  // Retour SAV lié (si commande créée pour échange SAV)
  productReturn ProductReturn?   @relation("SAVSubBoxOrder")

  @@index([subBoxId])
  @@index([storeId])
  @@index([clientCode])
  @@index([status])
  @@index([createdAt])
  @@map("sub_box_orders")
}

// Item d'une commande de sous-caisse
model SubBoxOrderItem {
  id            String   @id @default(cuid())
  subBoxOrderId String   @map("sub_box_order_id")
  productId     String   @map("product_id")
  
  // Snapshot du produit au moment de la création
  name          String   // Nom du produit
  sku           String?  // SKU du produit
  unitPrice     Float    @map("unit_price") // Prix unitaire
  discount      Float    @default(0)
  
  quantity      Int      // Quantité
  total         Float    // Total (unitPrice * quantity)
  
  createdAt     DateTime @default(now()) @map("created_at")

  subBoxOrder   SubBoxOrder @relation(fields: [subBoxOrderId], references: [id], onDelete: Cascade)

  @@index([subBoxOrderId])
  @@index([productId])
  @@map("sub_box_order_items")
}

// ============================================================================
// POINTAGE - TABLES
// ============================================================================

// Appareils autorisés pour le pointage
model AttendanceDevice {
  id          String                 @id @default(cuid())
  userId      String                 @map("user_id")
  deviceId    String                 @map("device_id") // UUID unique de l'appareil
  deviceName  String?                @map("device_name") // Ex: "iPhone 14 Pro"
  platform    String?                // "ios" ou "android"
  status      AttendanceDeviceStatus @default(PENDING)
  lastSeenAt  DateTime?              @map("last_seen_at")
  approvedBy  String?                @map("approved_by")
  approvedAt  DateTime?              @map("approved_at")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver User? @relation("DeviceApprover", fields: [approvedBy], references: [id])

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([deviceId])
  @@index([status])
  @@map("attendance_devices")
}

// Bornes de pointage
model AttendanceTerminal {
  id        String                   @id @default(cuid())
  code      String                   @unique // Ex: "ENTREE_BAT_A"
  name      String                   // Ex: "Entrée Bâtiment A"
  location  String?                  // Emplacement physique
  type      AttendanceTerminalType   @default(ENTRY_EXIT)
  status    AttendanceTerminalStatus @default(ACTIVE)
  secretKey String                   @map("secret_key") // Clé pour signer les QR
  createdAt DateTime                 @default(now()) @map("created_at")
  updatedAt DateTime                 @updatedAt @map("updated_at")

  qrTokens AttendanceQRToken[]
  logs     AttendanceLog[]

  @@index([code])
  @@index([status])
  @@map("attendance_terminals")
}

// Tokens QR éphémères (5 secondes)
model AttendanceQRToken {
  id         String    @id @default(cuid())
  token      String    @unique
  terminalId String    @map("terminal_id")
  issuedAt   DateTime  @default(now()) @map("issued_at")
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  usedBy     String?   @map("used_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  terminal AttendanceTerminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  user     User?              @relation(fields: [usedBy], references: [id])

  @@index([token])
  @@index([terminalId])
  @@index([expiresAt])
  @@map("attendance_qr_tokens")
}

// Historique des pointages
model AttendanceLog {
  id         String           @id @default(cuid())
  userId     String           @map("user_id")
  deviceId   String?          @map("device_id") // ID de l'appareil utilisé
  terminalId String?          @map("terminal_id")
  type       AttendanceType   // CHECK_IN ou CHECK_OUT
  method     AttendanceMethod @default(QR_CODE)
  timestamp  DateTime         @default(now())
  latitude   Float?
  longitude  Float?
  isFlagged  Boolean          @default(false) @map("is_flagged") // Anomalie détectée
  flagReason String?          @map("flag_reason")
  notes      String?
  createdAt  DateTime         @default(now()) @map("created_at")

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  terminal AttendanceTerminal? @relation(fields: [terminalId], references: [id])

  @@index([userId])
  @@index([timestamp])
  @@index([type])
  @@index([isFlagged])
  @@map("attendance_logs")
}

// ============================================================================
// MODULE COMPTABILITÉ - MODÈLES
// ============================================================================

// Catégories de dépenses (globales)
model ExpenseCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String?
  color       String?
  isActive    Boolean  @default(true) @map("is_active")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  expenses Expense[]

  @@index([isActive])
  @@map("expense_categories")
}

// Dépenses
model Expense {
  id              String             @id @default(cuid())
  storeId         String?            @map("store_id")
  categoryId      String             @map("category_id")
  
  title           String
  description     String?
  amount          Float
  
  supplierName    String?            @map("supplier_name")
  supplierPhone   String?            @map("supplier_phone")
  
  dueDate         DateTime           @map("due_date")
  periodicity     ExpensePeriodicity @default(ONCE)
  paymentDay      Int?               @map("payment_day")
  
  documentUrl     String?            @map("document_url")
  documentName    String?            @map("document_name")
  
  status          ExpenseStatus      @default(PENDING)
  paidAmount      Float              @default(0) @map("paid_amount")
  remainingAmount Float              @default(0) @map("remaining_amount")
  
  parentExpenseId String?            @map("parent_expense_id")
  isRecurring     Boolean            @default(false) @map("is_recurring")
  
  createdById     String             @map("created_by_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  store           Store?             @relation(fields: [storeId], references: [id], onDelete: SetNull)
  category        ExpenseCategory    @relation(fields: [categoryId], references: [id])
  createdBy       User               @relation("ExpenseCreator", fields: [createdById], references: [id])
  parentExpense   Expense?           @relation("RecurringExpenses", fields: [parentExpenseId], references: [id])
  childExpenses   Expense[]          @relation("RecurringExpenses")
  payments        ExpensePayment[]

  @@index([storeId])
  @@index([categoryId])
  @@index([status])
  @@index([dueDate])
  @@index([isRecurring])
  @@map("expenses")
}

// Paiements de dépenses
model ExpensePayment {
  id           String             @id @default(cuid())
  expenseId    String             @map("expense_id")
  
  amount       Float
  paymentDate  DateTime           @map("payment_date")
  paymentMode  ExpensePaymentMode @map("payment_mode")
  reference    String?
  
  receiptUrl   String?            @map("receipt_url")
  receiptName  String?            @map("receipt_name")
  notes        String?
  
  paidById     String             @map("paid_by_id")
  createdAt    DateTime           @default(now()) @map("created_at")

  expense      Expense            @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  paidBy       User               @relation("ExpensePaymentPayer", fields: [paidById], references: [id])

  @@index([expenseId])
  @@index([paymentDate])
  @@map("expense_payments")
}

// Codes de vérification pour l'accès à la comptabilité
model AccountingAccessCode {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  code        String   // Code à 6 chiffres
  expiresAt   DateTime @map("expires_at")
  isUsed      Boolean  @default(false) @map("is_used")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@map("accounting_access_codes")
}

